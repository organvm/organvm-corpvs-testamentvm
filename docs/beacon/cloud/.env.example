# Telos Beacon Protocol — environment variables (template)
# Copy to `.env` (gitignored) and fill in the values for your environment.
# Do NOT commit `.env`. Only this `.env.example` lives in git.

# ─────────────────────────────────────────────────────────────────────
# Core protocol identity
# ─────────────────────────────────────────────────────────────────────

# Version of the Beacon Protocol this agent operates under.
# Used in emission records' `producers` field for provenance.
BEACON_VERSION=1.0.0-tbp-001

# Repository root inside the container. Set automatically by devcontainer.json.
BEACON_REPO_ROOT=/workspaces/organvm-corpvs-testamentvm

# Logos directory (read-only for agents; humans author here).
BEACON_LOGOS_DIR=${BEACON_REPO_ROOT}/docs/logos

# Beacon directory (read-write for agents in /examples/ and append-only to /logos/receptio.md).
BEACON_BEACON_DIR=${BEACON_REPO_ROOT}/docs/beacon

# JSON Schema for emission records.
BEACON_SCHEMA_PATH=${BEACON_BEACON_DIR}/beacon-schema.json

# ─────────────────────────────────────────────────────────────────────
# Default emission parameters (override per-emission via CLI args)
# ─────────────────────────────────────────────────────────────────────

# Polarity: formal | aesthetic | mixed
BEACON_DEFAULT_POLARITY=mixed

# Reach radius: local | organ | system | public
BEACON_DEFAULT_REACH=system

# Frequency: weekly | biweekly | monthly | annual
BEACON_DEFAULT_FREQUENCY=biweekly

# Token-effort budget per chunk during tethered delivery.
BEACON_TETHER_BUDGET=5000

# Wire-level chunk size in bytes.
BEACON_CHUNK_SIZE=32768

# ─────────────────────────────────────────────────────────────────────
# Cloud storage — Cloudflare R2 + KV
# ─────────────────────────────────────────────────────────────────────

# Cloudflare API token. Scope: R2:read,write + KV:read,write on the
# `organvm-telos-beacon` bucket and `BEACON_INDEX` namespace ONLY.
# Generate at https://dash.cloudflare.com/profile/api-tokens.
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID (32-char hex). Inspect at the bottom-right of the dash.
CLOUDFLARE_ACCOUNT_ID=

# R2 bucket name. Provisioned via `r2_bucket_create` MCP tool on first run.
BEACON_R2_BUCKET=organvm-telos-beacon

# KV namespace ID. Provisioned via `kv_namespace_create` MCP tool on first run.
BEACON_KV_NAMESPACE_ID=

# Public Workers URL where the /emit endpoint is hosted. Set after deploy.
BEACON_WORKERS_ROUTE=https://beacon.organvm.workers.dev

# ─────────────────────────────────────────────────────────────────────
# Distribution channels — POSSE
# ─────────────────────────────────────────────────────────────────────

# Mastodon API token (scope: write:statuses). Optional — Beacon skips this
# channel if unset and logs a `BEACON-NEWSLETTER-SKIP-NNN`-style event.
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# Discord webhook URL for #telos-beacon channel. Optional.
DISCORD_WEBHOOK_URL=

# Newsletter provider API key (Buttondown / ConvertKit / Listmonk). Optional.
NEWSLETTER_PROVIDER=buttondown
NEWSLETTER_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Codex Cloud agent invocation
# ─────────────────────────────────────────────────────────────────────

# OpenAI API key (for Codex Cloud agent dispatch). Optional — Beacon
# distributes via POSSE + Workers without the agent leg if unset.
OPENAI_API_KEY=

# Codex Cloud agent role identifier. Should match the agent registered at
# https://platform.openai.com/codex/cloud/.
CODEX_AGENT_ID=organvm-telos-beacon-agent

# Maximum tokens per agent invocation. Per OpenAI quota.
CODEX_MAX_TOKENS=8000

# ─────────────────────────────────────────────────────────────────────
# Optional — signed emissions (Ed25519)
# ─────────────────────────────────────────────────────────────────────

# Private signing key (32-byte hex). DO NOT COMMIT. Optional — if absent,
# emissions ship with `signed: false`.
BEACON_SIGNING_KEY=

# Public URL where receivers fetch the corresponding verification key.
# Stored in this repo at docs/beacon/signing-key.pub (commit the .pub only).
BEACON_SIGNING_KEY_URI=https://raw.githubusercontent.com/a-organvm/organvm-corpvs-testamentvm/main/docs/beacon/signing-key.pub

# ─────────────────────────────────────────────────────────────────────
# GitHub App / actions integration (for the orchestrator workflow)
# ─────────────────────────────────────────────────────────────────────

# GitHub App ID for the Beacon emit workflow. Optional — falls back to
# GITHUB_TOKEN injected by Actions.
BEACON_GITHUB_APP_ID=

# GitHub App private key (PEM, base64-encoded for env transport). Optional.
BEACON_GITHUB_APP_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────────

# Sentry DSN for error reporting. Optional.
SENTRY_DSN=

# Log level: DEBUG | INFO | WARNING | ERROR
BEACON_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────
# Provenance / debugging
# ─────────────────────────────────────────────────────────────────────

# Set to '1' to disable distribution (dry-run mode). Useful during agent
# testing. Beacon still writes to local SQLite + R2 but skips POSSE +
# Codex legs.
BEACON_DRY_RUN=0

# Set to '1' to skip the privacy/legal/security gates in ALCHEMIZE.
# WARNING: only for local-only test emissions. Production emissions must
# never set this.
BEACON_SKIP_GATES=0
