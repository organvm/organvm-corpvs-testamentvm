#!/usr/bin/env bash
# organvm.env — System-wide org name configuration
# TEMPLATE: Fork this file and set your own values.
# Usage: source organvm.env && echo "$ORGAN_III_ORG"

set -euo pipefail

# The prefix. Change this one value and all 8 orgs derive from it.
ORGAN_PREFIX="${ORGAN_PREFIX:-organvm}"

# Ontological suffixes (Greek, matching organ function)
ORGAN_I_SUFFIX="${ORGAN_I_SUFFIX:-i-theoria}"      # θεωρία — contemplation, theory
ORGAN_II_SUFFIX="${ORGAN_II_SUFFIX:-ii-poiesis}"    # ποίησις — making, artistic creation
ORGAN_III_SUFFIX="${ORGAN_III_SUFFIX:-iii-ergon}"    # ἔργον — work, deed, product
ORGAN_IV_SUFFIX="${ORGAN_IV_SUFFIX:-iv-taxis}"      # τάξις — arrangement, order, governance
ORGAN_V_SUFFIX="${ORGAN_V_SUFFIX:-v-logos}"          # λόγος — word, speech, reason
ORGAN_VI_SUFFIX="${ORGAN_VI_SUFFIX:-vi-koinonia}"    # κοινωνία — communion, fellowship
ORGAN_VII_SUFFIX="${ORGAN_VII_SUFFIX:-vii-kerygma}"  # κήρυγμα — proclamation, announcement

# Derived org names (override individually if needed)
ORGAN_I_ORG="${ORGAN_I_ORG:-${ORGAN_PREFIX}-${ORGAN_I_SUFFIX}}"
ORGAN_II_ORG="${ORGAN_II_ORG:-${ORGAN_PREFIX}-${ORGAN_II_SUFFIX}}"
ORGAN_III_ORG="${ORGAN_III_ORG:-${ORGAN_PREFIX}-${ORGAN_III_SUFFIX}}"
ORGAN_IV_ORG="${ORGAN_IV_ORG:-${ORGAN_PREFIX}-${ORGAN_IV_SUFFIX}}"
ORGAN_V_ORG="${ORGAN_V_ORG:-${ORGAN_PREFIX}-${ORGAN_V_SUFFIX}}"
ORGAN_VI_ORG="${ORGAN_VI_ORG:-${ORGAN_PREFIX}-${ORGAN_VI_SUFFIX}}"
ORGAN_VII_ORG="${ORGAN_VII_ORG:-${ORGAN_PREFIX}-${ORGAN_VII_SUFFIX}}"

# Meta-org (umbrella above all 8 organs)
META_ORG="${META_ORG:-meta-${ORGAN_PREFIX}}"

# Personal account (for orphan classification)
PERSONAL_ACCOUNT="${PERSONAL_ACCOUNT:-}"

# ============================================================================
# ELEVATED-FORM EXTENSION (added 2026-05-27)
# The 8-organ-org topology above is the legacy form. The elevated form
# collapses to 2 orgs (PERSONAL + SYSTEM) with the 8-organ taxonomy preserved
# as seed.yaml + GitHub topics + double-hyphen naming. See standards/19.
# ============================================================================

# === 2-ORG TARGET TOPOLOGY ===
ORG_PERSONAL="${ORG_PERSONAL:-4444J99}"
ORG_SYSTEM="${ORG_SYSTEM:-${ORGAN_PREFIX}}"           # bare-essence target; falls back to a-organvm pre-rename via .env.local
ORG_SYSTEM_TEMPLATE="${ORG_SYSTEM_TEMPLATE:-${ORG_SYSTEM}/.github}"
PERSONAL_ACCOUNT="${PERSONAL_ACCOUNT:-${ORG_PERSONAL}}"  # backfill the existing var

# === CONDUCTOR IDENTITY ===
CONDUCTOR_LABEL_PREFIX="${CONDUCTOR_LABEL_PREFIX:-conductor}"
CONDUCTOR_EMAIL="${CONDUCTOR_EMAIL:-etceter4@etceter4.com}"

# === CANONICAL ROOTS ===
CORPVS_ROOT="${CORPVS_ROOT:-${HOME}/Code/organvm/organvm-corpvs-testamentvm}"
DOMUS_ROOT="${DOMUS_ROOT:-${HOME}/Workspace/${ORG_PERSONAL}/domus-semper-palingenesis}"
SKILLS_ROOT="${SKILLS_ROOT:-${HOME}/Code/organvm/a-i--skills}"
AUDIT_ROOT="${AUDIT_ROOT:-${HOME}/.claude/scheduled-tasks/audit}"
SCHED_TASKS_ROOT="${SCHED_TASKS_ROOT:-${HOME}/.claude/scheduled-tasks}"
LAUNCHD_STATE_ROOT="${LAUNCHD_STATE_ROOT:-${HOME}/.local/share/conductor-launchd}"

# === CANONICAL STANDARDS DOCS (referenced by env var, never literal path) ===
STANDARDS_DIR="${STANDARDS_DIR:-${CORPVS_ROOT}/docs/standards}"
DOC_REPO_STANDARDS="${STANDARDS_DIR}/10-repository-standards.md"
DOC_SDD="${STANDARDS_DIR}/11-specification-driven-development.md"
DOC_BRANCH_GOVERNANCE="${STANDARDS_DIR}/17-branch-governance.md"
DOC_SCHEDULED_PROCESS_CONTRACT="${STANDARDS_DIR}/18-scheduled-process-contract.md"
DOC_TWO_ORG_ARCHITECTURE="${STANDARDS_DIR}/19-two-org-consolidation-architecture.md"
DOC_REUSABLE_WORKFLOW_ARCHITECTURE="${STANDARDS_DIR}/20-reusable-workflow-architecture.md"
DOC_APPS_SURFACE_POLICY="${STANDARDS_DIR}/21-apps-surface-policy.md"
DOC_NAMING_CONVENTION="${STANDARDS_DIR}/22-essence-function-naming-convention.md"
IRF_INDEX="${IRF_INDEX:-${CORPVS_ROOT}/INST-INDEX-RERUM-FACIENDARUM.md}"
REGISTRY_V2="${REGISTRY_V2:-${CORPVS_ROOT}/registry-v2.json}"

# === CLASS-(I) LOCAL-TOKEN ROUTINES (essence--function compound) ===
ROUTINE_HOOK_DRIFT_PROBE="hook-drift-probe--settings-template-diff"
ROUTINE_WORKTREE_WARDEN="worktree-warden--triage-clean-safe"
ROUTINE_REPO_WARDEN="repo-warden--unpushed-orphan-push"
ROUTINE_PR_CASCADE="pr-cascade--tier-merge-report"
ROUTINE_COMMIT_SUMMARIZER="commit-summarizer--push-retrospective"
ROUTINE_IRF_DECAY_MONITOR="irf-decay-monitor--aging-shipped-windows-weekly"
ROUTINE_SCOPE_PATTERN_WITNESS="scope-pattern-witness--cross-emergence-weekly"
ROUTINE_LAUNCHAGENT_AUDITOR="launchagent-auditor--rule55a-three-bucket-monthly"

# === CLASS-(II) RULE-#55a LAUNCHAGENTS ===
LA_LABEL_PREFIX="com.${CONDUCTOR_LABEL_PREFIX}"
LA_SUMMON_DAILY="${LA_LABEL_PREFIX}.archive-summon--daily-md-scrub"

# === CLASS-(III) SERVER-SIDE REUSABLE WORKFLOWS ===
WF_BASE="${ORG_SYSTEM_TEMPLATE}/.github/workflows"
WF_STALE_WARDEN="${WF_BASE}/stale-warden--issue-pr-close.yml"
WF_REPO_AUDITOR="${WF_BASE}/repo-state-auditor--unpushed-orphan-report.yml"
WF_PR_CASCADE="${WF_BASE}/pr-cascade--tier-merge-report.yml"
WF_COMMIT_SUMMARIZER="${WF_BASE}/commit-summarizer--push-retrospective.yml"
WF_METRICS_REFRESHER="${WF_BASE}/metrics-refresher--corpvs-daily.yml"
WF_SOAK_PROBER="${WF_BASE}/soak-prober--corpvs-daily.yml"
WF_SYSTEM_PULSE="${WF_BASE}/system-pulse--corpvs-weekly.yml"
WF_ORGAN_AUDITOR="${WF_BASE}/organ-auditor--corpvs-monthly.yml"

# === CLASS-(IV) APPS SLOTS ===
APP_PRIMARY_AGENT="${APP_PRIMARY_AGENT:-claude}"
APP_DEPENDENCY_SCANNER="${APP_DEPENDENCY_SCANNER:-dependabot}"
APP_PR_REVIEWER="${APP_PR_REVIEWER:-coderabbitai}"
APP_SAST_SCANNER="${APP_SAST_SCANNER:-semgrep-app}"
APP_SECRET_SCANNER="${APP_SECRET_SCANNER:-gitguardian}"
APP_DEPLOY_TARGET="${APP_DEPLOY_TARGET:-vercel}"
APP_CI_BUILDER="${APP_CI_BUILDER:-google-cloud-build}"
APP_PROJECT_TRACKER="${APP_PROJECT_TRACKER:-linear-code}"

# === SELF-AUDIT WITNESS ROUTINES (the closing-the-loop layer) ===
ROUTINE_TOPOLOGY_WITNESS="org-topology-witness--two-org-invariant-daily"
ROUTINE_APPS_DORMANCY_WITNESS="apps-dormancy-witness--30day-zero-activity-weekly"
ROUTINE_REUSABLE_COVERAGE_WITNESS="reusable-coverage-witness--per-repo-caller-check-weekly"

# Export all variables (existing + elevated)
export ORGAN_PREFIX
export ORGAN_I_SUFFIX ORGAN_II_SUFFIX ORGAN_III_SUFFIX ORGAN_IV_SUFFIX
export ORGAN_V_SUFFIX ORGAN_VI_SUFFIX ORGAN_VII_SUFFIX
export ORGAN_I_ORG ORGAN_II_ORG ORGAN_III_ORG ORGAN_IV_ORG
export ORGAN_V_ORG ORGAN_VI_ORG ORGAN_VII_ORG
export META_ORG PERSONAL_ACCOUNT
export ORG_PERSONAL ORG_SYSTEM ORG_SYSTEM_TEMPLATE
export CONDUCTOR_LABEL_PREFIX CONDUCTOR_EMAIL
export CORPVS_ROOT DOMUS_ROOT SKILLS_ROOT AUDIT_ROOT SCHED_TASKS_ROOT LAUNCHD_STATE_ROOT
export STANDARDS_DIR DOC_REPO_STANDARDS DOC_SDD DOC_BRANCH_GOVERNANCE
export DOC_SCHEDULED_PROCESS_CONTRACT DOC_TWO_ORG_ARCHITECTURE
export DOC_REUSABLE_WORKFLOW_ARCHITECTURE DOC_APPS_SURFACE_POLICY DOC_NAMING_CONVENTION
export IRF_INDEX REGISTRY_V2
export ROUTINE_HOOK_DRIFT_PROBE ROUTINE_WORKTREE_WARDEN ROUTINE_REPO_WARDEN
export ROUTINE_PR_CASCADE ROUTINE_COMMIT_SUMMARIZER ROUTINE_IRF_DECAY_MONITOR
export ROUTINE_SCOPE_PATTERN_WITNESS ROUTINE_LAUNCHAGENT_AUDITOR
export LA_LABEL_PREFIX LA_SUMMON_DAILY
export WF_BASE WF_STALE_WARDEN WF_REPO_AUDITOR WF_PR_CASCADE WF_COMMIT_SUMMARIZER
export WF_METRICS_REFRESHER WF_SOAK_PROBER WF_SYSTEM_PULSE WF_ORGAN_AUDITOR
export APP_PRIMARY_AGENT APP_DEPENDENCY_SCANNER APP_PR_REVIEWER APP_SAST_SCANNER
export APP_SECRET_SCANNER APP_DEPLOY_TARGET APP_CI_BUILDER APP_PROJECT_TRACKER
export ROUTINE_TOPOLOGY_WITNESS ROUTINE_APPS_DORMANCY_WITNESS ROUTINE_REUSABLE_COVERAGE_WITNESS
