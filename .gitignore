# Instance-specific config (contains personal org names)
.config/organvm.env.local

# macOS
.DS_Store

# Claude Code session exports (transcripts are on-demand, never committed — per CLAUDE.md)
*-local-command-caveatcaveat-the-messages-below.txt
export-*.md

# Untriaged memory harvest staging — classify and route before tracking
/memory/

# Scratch/working files
.scratch/

# Python bytecode (from scripts/, scripts/plugins/, etc.)
__pycache__/
*.pyc
*.pyo

# Bulk atom pipeline outputs (committed summaries + manifest only)
data/atoms/*.jsonl

# Personal clipboard exports must NEVER land in this public repo. The heartbeat routes
# them to ~/.cache (untracked); this is a defense-in-depth net against the engine's
# default --output-dir landing one here. (leak-vector hygiene)
data/atoms/ai-prompts-clipboard-export.*

# Corpus pipeline outputs (events.jsonl can run very large; regenerable from sources)
# IRF-SEC-010 resolution: ignore rather than LFS-track
data/corpus/*/events.jsonl

# Prompt registry pipeline outputs (regenerable via extract→atomize→triage→measure→route)
# See data/prompt-registry/README.md for regeneration commands
data/prompt-registry/*.json
